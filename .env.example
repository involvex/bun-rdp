# ── Server ────────────────────────────────────────────────
PORT=9001
FPS=30
BITRATE=2000000
AUDIO=true

# ── TLS ────────────────────────────────────────────────────
# "auto"   — generate self-signed cert on first run (default)
# "custom" — use BUN_RDP_CERT + BUN_RDP_KEY
# "off"    — plain ws:// (LAN or behind TLS proxy)
BUN_RDP_TLS=auto

# Only needed when BUN_RDP_TLS=custom:
# BUN_RDP_CERT=/path/to/fullchain.pem
# BUN_RDP_KEY=/path/to/privkey.pem

# ── Auth ───────────────────────────────────────────────────
# REQUIRED in production — random 64-char hex string
BUN_RDP_SECRET=change_me_to_a_random_64char_hex_string

# Token TTLs (milliseconds)
BUN_RDP_SESSION_TTL_MS=3600000      # 1 hour
BUN_RDP_REFRESH_TTL_MS=86400000     # 24 hours
BUN_RDP_ONETIME_TTL_MS=3600000      # 1 hour

# Print a one-time share link on startup:
# BUN_RDP_PRINT_TOKEN=1

# ── IP Allowlist ───────────────────────────────────────────
# Comma-separated IPs / CIDRs, or * for all (default)
# BUN_RDP_ALLOW_IPS=192.168.1.0/24,10.0.0.1,::1

# ── Rate limiter ───────────────────────────────────────────
BUN_RDP_RATE_WINDOW_MS=60000        # 1 minute window
BUN_RDP_RATE_MAX_CONN=10            # max connections per window
BUN_RDP_RATE_MAX_AUTH=5             # max failed auth per window
BUN_RDP_RATE_BAN_MS=300000          # 5 minute ban

# ── Data directory (certs, audit log) ─────────────────────
BUN_RDP_DATA_DIR=.rdp-data

# ── Logging ────────────────────────────────────────────────
LOG_LEVEL=info
